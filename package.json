{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && tsx prisma/seed.ts",
    "db:migrate-booking": "tsx prisma/migrate-booking.ts",
    "db:migrate": "tsx prisma/migrate-booking.ts && tsx prisma/migrate-booking-theme.ts && tsx prisma/migrate-booking-type.ts && tsx prisma/migrate-calendar.ts && tsx prisma/migrate-cms.ts && tsx prisma/migrate-analytics.ts",
    "stripe:setup": "tsx scripts/stripe-setup.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@libsql/client": "^0.17.2",
    "@octokit/rest": "^22.0.1",
    "@prisma/adapter-libsql": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@types/bcryptjs": "^2.4.6",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^3.0.3",
    "next": "16.2.3",
    "next-auth": "^5.0.0-beta.31",
    "openai": "^6.34.0",
    "prisma": "^7.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.11.0",
    "stripe": "^22.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
